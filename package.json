{
  "name": "doan3-root",
  "version": "1.0.0",
  "scripts": {
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "cd Backend/my-node-app && npm start",
    "start:frontend": "cd Frontend/my-react && npm run dev",
    "install:all": "npm install && cd Backend/my-node-app && npm install && cd ../../Frontend/my-react && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.14"
  },
  "dependencies": {
    "html2pdf.js": "^0.14.0",
    "multer": "^2.1.1"
  }
}
